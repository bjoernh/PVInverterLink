<!DOCTYPE html>
<html class="h-full">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>{% block title %}{% endblock %}</title>
    <link rel="stylesheet" href="/static/output.css" type="text/css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" integrity="sha512-z3gLpd7yknf1YoNbCzqRKc4qyor8gaKU1qmn+CShxbuBusANI9QpRohGBreCFkKxLhei6S9CQXFEbbKuqLg0DA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
</head>
<body class="h-full" hx-boost="true">

  <header class="navbar bg-base-100">
    <div class="navbar-start">
      {% if user %}
      <div class="dropdown">
        <label tabindex="0" class="btn btn-ghost btn-circle">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7" /></svg>
        </label>
        <ul tabindex="0" class="menu menu-sm dropdown-content mt-3 z-[1] p-2 shadow bg-base-100 rounded-box w-52">
          <li><a href="/" hx-push-url="true">Home</a></li>
          {% if user.is_verified %}
          <li><a href="/inverters" hx-push-url="true">Wechselrichter</a></li>
          {% else %}
          <li class="disabled"><a class="text-base-300">Wechselrichter (Email verifizieren)</a></li>
          {% endif %}
          <li><a href="/account" hx-push-url="true">Konto Verwalten</a></li>
          <li><a href="/logout" hx-push-url="true">Logout</a></li>
        </ul>
      </div>
      {% endif %}
    </div>
    <div class="navbar-center">
      <a href="/" hx-push-url="true" class="btn btn-ghost normal-case text-xl">Deye Hard</a>
    </div>
    <div class="navbar-end">
        <label class="swap swap-rotate btn btn-ghost btn-circle">
            <!-- this hidden checkbox controls the state -->
            <input type="checkbox" id="theme-toggle-checkbox" />
            
            <!-- sun icon (shown when unchecked / light mode) -->
            <div class="swap-off flex items-center justify-center">
                <svg class="h-8 w-8 fill-amber-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                    <path d="M5.64,17l-.71.71a1,1,0,0,0,0,1.41,1,1,0,0,0,1.41,0l.71-.71A1,1,0,0,0,5.64,17ZM5,12a1,1,0,0,0-1-1H3a1,1,0,0,0,0,2H4A1,1,0,0,0,5,12Zm7-7a1,1,0,0,0,1-1V3a1,1,0,0,0-2,0V4A1,1,0,0,0,12,5ZM5.64,7.05a1,1,0,0,0,.7.29,1,1,0,0,0,.71-.29,1,1,0,0,0,0-1.41l-.71-.71A1,1,0,0,0,4.93,6.34Zm12,.29a1,1,0,0,0,.7-.29l.71-.71a1,1,0,1,0-1.41-1.41L17,5.64a1,1,0,0,0,0,1.41A1,1,0,0,0,17.66,7.34ZM21,11H20a1,1,0,0,0,0,2h1a1,1,0,0,0,0-2Zm-9,8a1,1,0,0,0-1,1v1a1,1,0,0,0,2,0V20A1,1,0,0,0,12,19ZM18.36,17A1,1,0,0,0,17,18.36l.71.71a1,1,0,0,0,1.41,0,1,1,0,0,0,0-1.41ZM12,6.5A5.5,5.5,0,1,0,17.5,12,5.51,5.51,0,0,0,12,6.5Zm0,9A3.5,3.5,0,1,1,15.5,12,3.5,3.5,0,0,1,12,15.5Z"/>
                </svg>
            </div>
            
            <!-- moon icon (shown when checked / dark mode) -->
            <div class="swap-on flex items-center justify-center">
                <svg class="h-8 w-8 fill-white" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                    <path d="M21.64,13a1,1,0,0,0-1.05-.14,8.05,8.05,0,0,1-3.37.73A8.15,8.15,0,0,1,9.08,5.49a8.59,8.59,0,0,1,.25-2A1,1,0,0,0,8,2.36,10.14,10.14,0,1,0,22,14.05,1,1,0,0,0,21.64,13Zm-9.5,6.69A8.14,8.14,0,0,1,7.08,5.22,10.27,10.27,0,0,0,12,19.82,10.72,10.72,0,0,0,12.14,19.69Z"/>
                </svg>
            </div>
        </label>
    </div>
  </header>
    <main class="flex flex-col px-4 md:px-6 lg:px-8 overflow-x-hidden">
      <div id="alert">
      </div>
    {% block content %}

    {% endblock %}
    </main>
  {% block footer %}
  <footer class="flex items-center py-1 px-2 md:py-2 md:px-4 bg-neutral text-neutral-content justify-between gap-4">
    <div class="flex items-center gap-1 md:gap-2">
      <span class="text-sm md:text-base">Made with ❤️ by</span>
      <span class="font-bold text-sm md:text-base">WTF e.G.</span>
    </div>
    <nav class="flex gap-2 md:gap-4">
      <a href="https://chaos.social/@HackerGeno"><i class="fa-brands fa-mastodon fa-lg"></i></a>
      <a href="https://github.com/wtf-eg/project"><i class="fa-brands fa-github fa-lg"></i></a>
    </nav>
  </footer>
        {% endblock %}
    </div>
    <script src="https://unpkg.com/htmx.org@2.0.7/dist/htmx.min.js"></script>
    <script src="https://unpkg.com/htmx-ext-json-enc@2.0.1/json-enc.js"></script>
    <script src="https://cdn.plot.ly/plotly-2.27.0.min.js"></script>
    <script>
      // New Theme Switcher Implementation - Made idempotent for HTMX
      (function() {
        if (window.__THEME_INITIALIZED) return;
        
        window.THEME_KEY = 'pvinverter_theme';
        
        window.getSavedTheme = function() {
          return localStorage.getItem(window.THEME_KEY) || 
                 (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        };

        window.applyTheme = function(theme) {
          document.documentElement.setAttribute('data-theme', theme);
          localStorage.setItem(window.THEME_KEY, theme);
          
          // Update checkbox state if it exists
          const checkbox = document.getElementById('theme-toggle-checkbox');
          if (checkbox) {
            checkbox.checked = (theme === 'dark');
          }

          // Trigger re-init for any active chart pages
          if (document.getElementById('powerChart') && typeof window.initializeSummaryDashboard === 'function') {
             window.initializeSummaryDashboard();
          } else if (document.getElementById('powerChart') && typeof window.initializeInverterDashboard === 'function') {
             window.initializeInverterDashboard();
          } else if (document.getElementById('comparisonChart') && typeof window.initializeDCChannels === 'function') {
             window.initializeDCChannels();
          }
        };

        window.initThemeToggle = function() {
          const checkbox = document.getElementById('theme-toggle-checkbox');
          if (checkbox) {
            // Set initial state
            checkbox.checked = (window.getSavedTheme() === 'dark');
            
            // Remove old listener if re-initializing
            checkbox.removeEventListener('change', window.__themeToggleHandler);
            
            // Define new handler
            window.__themeToggleHandler = function() {
              const newTheme = this.checked ? 'dark' : 'light';
              window.applyTheme(newTheme);
            };
            
            // Add listener
            checkbox.addEventListener('change', window.__themeToggleHandler);
          }
        };

        // Initial apply (fast, before DOM ready if possible)
        window.applyTheme(window.getSavedTheme());
        window.__THEME_INITIALIZED = true;
      })();

      // Global interval management for graph auto-refresh
      window.currentInterval = null;
      window.stopActiveInterval = function() {
        if (window.currentInterval) {
          clearInterval(window.currentInterval);
          window.currentInterval = null;
          console.log('Cleared auto-refresh interval');
        }
      };

      // Stop intervals and clear functions *before* navigation to prevent stale state
      document.body.addEventListener('htmx:beforeRequest', function(evt) {
        window.stopActiveInterval();
        window.initializeSummaryDashboard = null;
        window.initializeInverterDashboard = null;
        window.initializeDCChannels = null;
      });

      // Reinitialize after HTMX swaps
      document.body.addEventListener('htmx:afterSwap', function(evt) {
        if (typeof window.initThemeToggle === 'function') {
          window.initThemeToggle();
        }
      });

      // DOM Content Loaded for initial page load
      document.addEventListener('DOMContentLoaded', function() {
        if (typeof window.initThemeToggle === 'function') {
          window.initThemeToggle();
        }
      });
    </script>
</body>
</html>
